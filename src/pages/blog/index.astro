---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// Parse date from filename (format: YYYYMMDD_HHmmss_title)
function parseDateFromId(id: string): Date {
  const match = id.match(/^(\d{4})(\d{2})(\d{2})_(\d{2})(\d{2})(\d{2})/);
  if (!match) return new Date(0);
  const [, y, m, d, hh, mm, ss] = match;
  return new Date(`${y}-${m}-${d}T${hh}:${mm}:${ss}`);
}

// Sort descending by filename (latest first)
const posts = (await getCollection('blog')).sort(
  (a, b) => b.id.localeCompare(a.id)
);

const POSTS_PER_PAGE = 5;
const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);
---

<Layout title="Blog | Malik Fajar Mubarok" description="Writing about work, explorations, and anything in between.">
  <header class="site-header">
    <nav>
      <a href="/" class="nav-home">Malik Fajar Mubarok</a>
      <a href="/blog" class="nav-link active">Blog</a>
      <a href="/cv" class="nav-link">CV</a>
      <a href="/cats" class="nav-link">Cats</a>
    </nav>
  </header>

  <main class="blog-listing" data-per-page={POSTS_PER_PAGE}>
    <h1>Blog</h1>
    <p class="subtitle">Writing about work, explorations, and anything in between.</p>

    <ul class="post-list" id="post-list">
      {posts.map((post, i) => {
        const postDate = parseDateFromId(post.id);
        return (
        <li class="post-item" data-index={i} style={i >= POSTS_PER_PAGE ? 'display:none;' : ''}>
          <a href={`/blog/${post.id}`}>
            <h2>{post.data.title}</h2>
            <time datetime={postDate.toISOString()}>
              {postDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            {post.data.description && <p>{post.data.description}</p>}
          </a>
        </li>
        );
      })}
    </ul>

    {totalPages > 1 && (
      <nav class="blog-pagination" id="blog-pagination">
        <button class="page-btn" id="first-btn" disabled>First</button>
        <button class="page-btn" id="prev-btn" disabled>← Prev</button>
        <span class="page-info" id="page-info">Page 1 of {totalPages}</span>
        <button class="page-btn" id="next-btn">Next →</button>
        <button class="page-btn" id="last-btn">Last</button>
      </nav>
    )}
  </main>

  <footer class="site-footer">
    <p>&copy; {new Date().getFullYear()} Malik Fajar Mubarok</p>
  </footer>
</Layout>

<style>
  .site-header {
    padding: 1rem 2rem;
  }

  .site-header nav {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-home {
    font-weight: 600;
    font-size: 1.1rem;
    color: #1a3a6b;
  }

  .nav-link {
    font-size: 0.95rem;
    color: #4a6a9b;
  }

  .nav-link.active {
    color: #1a3a6b;
    font-weight: 500;
  }

  .blog-listing {
    max-width: 700px;
    margin: 2rem auto 4rem;
    padding: 0 2rem;
  }

  .blog-listing h1 {
    font-family: 'Lora', Georgia, serif;
    font-size: 2rem;
    color: #1a3a6b;
    margin: 0 0 0.5rem;
  }

  .subtitle {
    color: #7a8a9b;
    font-style: italic;
    margin: 0 0 2.5rem;
    font-size: 1rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #e0dbd4;
  }

  .post-item:last-child {
    border-bottom: none;
  }

  .post-item a {
    display: block;
    text-decoration: none;
    transition: transform 0.15s ease;
  }

  .post-item a:hover {
    transform: translateX(4px);
  }

  .post-item h2 {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.3rem;
    color: #1a3a6b;
    margin: 0 0 0.3rem;
    font-weight: 600;
  }

  .post-item time {
    font-size: 0.85rem;
    color: #7a8a9b;
    font-style: italic;
  }

  .post-item p {
    font-size: 0.95rem;
    color: #4a4a4a;
    margin: 0.5rem 0 0;
    line-height: 1.6;
  }

  /* ── Pagination ── */
  .blog-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin-top: 2rem;
    padding: 1rem 0;
    flex-wrap: wrap;
  }

  .page-btn {
    padding: 0.5rem 1rem;
    border: 1px solid #c8d8e8;
    border-radius: 4px;
    background: #fffef9;
    color: #1a3a6b;
    font-family: 'Lora', Georgia, serif;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .page-btn:hover:not(:disabled) {
    background: #1a3a6b;
    color: #fffef9;
    border-color: #1a3a6b;
  }

  .page-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .page-info {
    font-size: 0.9rem;
    color: #4a6a9b;
    font-style: italic;
  }

  .site-footer {
    text-align: center;
    padding: 2rem;
    color: #7a8a9b;
    font-size: 0.85rem;
  }
</style>

<script is:inline>
  (function() {
    var container = document.querySelector('.blog-listing');
    var perPage = parseInt(container && container.dataset.perPage || '5', 10);
    var items = document.querySelectorAll('.post-item');
    var totalPages = Math.ceil(items.length / perPage);
    var currentPage = 1;

    if (totalPages <= 1) return;

    var firstBtn = document.getElementById('first-btn');
    var prevBtn = document.getElementById('prev-btn');
    var nextBtn = document.getElementById('next-btn');
    var lastBtn = document.getElementById('last-btn');
    var pageInfo = document.getElementById('page-info');

    function showPage(page) {
      currentPage = page;
      var start = (page - 1) * perPage;
      var end = start + perPage;

      items.forEach(function(item, i) {
        item.style.display = (i >= start && i < end) ? '' : 'none';
      });

      // Re-apply last-child border logic: remove bottom border from last visible item
      var visibleItems = Array.from(items).filter(function(item) {
        return item.style.display !== 'none';
      });
      visibleItems.forEach(function(item, i) {
        item.style.borderBottom = i === visibleItems.length - 1 ? 'none' : '';
      });

      if (firstBtn) firstBtn.disabled = page <= 1;
      if (prevBtn) prevBtn.disabled = page <= 1;
      if (nextBtn) nextBtn.disabled = page >= totalPages;
      if (lastBtn) lastBtn.disabled = page >= totalPages;
      if (pageInfo) pageInfo.textContent = 'Page ' + page + ' of ' + totalPages;

      container.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    if (firstBtn) firstBtn.addEventListener('click', function() { showPage(1); });
    if (prevBtn) prevBtn.addEventListener('click', function() { showPage(currentPage - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function() { showPage(currentPage + 1); });
    if (lastBtn) lastBtn.addEventListener('click', function() { showPage(totalPages); });
  })();
</script>
