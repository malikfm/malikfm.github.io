---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="CV | Malik Fajar Mubarok" description="Curriculum Vitae of Malik Fajar Mubarok">
  <header class="site-header">
    <nav>
      <a href="/" class="nav-home">Malik Fajar Mubarok</a>
      <a href="/blog" class="nav-link">Blog</a>
      <a href="/cv" class="nav-link active">CV</a>
      <a href="/cats" class="nav-link">Cats</a>
    </nav>
  </header>

  <main class="cv-page">
    <h1>Curriculum Vitae</h1>
    <div class="cv-embed">
      <iframe
        src="/malikfm_cv.pdf#toolbar=0"
        title="Malik Fajar Mubarok — CV"
        width="100%"
        height="100%"
      ></iframe>
    </div>
  </main>

  <footer class="site-footer">
    <p>&copy; {new Date().getFullYear()} Malik Fajar Mubarok</p>
  </footer>
</Layout>

<style>
  .site-header {
    padding: 1rem 2rem;
  }

  .site-header nav {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-home {
    font-weight: 600;
    font-size: 1.1rem;
    color: #1a3a6b;
  }

  .nav-link {
    font-size: 0.95rem;
    color: #4a6a9b;
  }

  .nav-link.active {
    color: #1a3a6b;
    font-weight: 500;
  }

  .cv-page {
    max-width: 900px;
    margin: 2rem auto;
    padding: 0 2rem;
  }

  .cv-page h1 {
    font-family: 'Lora', Georgia, serif;
    font-size: 2rem;
    color: #1a3a6b;
    margin: 0 0 1rem;
  }

  .cv-embed {
    width: 100%;
    height: 80vh;
    border: 1px solid #c8d8e8;
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .cv-embed iframe {
    border: none;
  }

  .site-footer {
    text-align: center;
    padding: 2rem;
    color: #7a8a9b;
    font-size: 0.85rem;
  }
</style>
