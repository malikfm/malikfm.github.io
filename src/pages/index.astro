    </section>
  </main>

  <footer class="site-footer">
    <p>&copy; {new Date().getFullYear()} Malik Fajar Mubarok</p>
  </footer>
</Layout>

<style>
  .site-header {
    padding: 1rem 2rem;
  }

  .site-header nav {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-home {
    font-weight: 600;
    font-size: 1.1rem;
    color: #1a3a6b;
  }

  .nav-link {
    font-size: 0.95rem;
    color: #4a6a9b;
  }

  .nav-link:hover {
    color: #1a3a6b;
  }

  .home {
    max-width: 700px;
    margin: 4rem auto;
    padding: 0 2rem;
  }

  .intro h1 {
    font-family: 'Lora', Georgia, serif;
    font-size: 2.2rem;
    color: #1a3a6b;
    margin: 0 0 1.5rem;
    font-weight: 700;
  }

  .intro p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #3a3a3a;
    margin: 0 0 1rem;
  }

  .read-blog {
    display: inline-block;
    margin-top: 1.5rem;
    padding: 0.75rem 1.5rem;
    background: #1a3a6b;
    color: #fffef9;
    border-radius: 6px;
    font-family: 'Lora', Georgia, serif;
    font-size: 1rem;
    transition: background 0.2s ease;
  }

  .read-blog:hover {
    background: #0d2d5e;
    color: #fffef9;
  }

  .social-links {
    display: flex;
    gap: 1rem;
    margin-top: 1.8rem;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: #4a6a9b;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .social-icon:hover {
    color: #1a3a6b;
    transform: translateY(-2px);
  }

  .social-icon svg {
    width: 24px;
    height: 24px;
  }

  .site-footer {
    text-align: center;
    padding: 2rem;
    color: #7a8a9b;
    font-size: 0.85rem;
  }

  @media (max-width: 768px) {
    .home {
      margin: 2rem auto;
    }

    .intro h1 {
      font-size: 1.6rem;
    }
  }
</style>
